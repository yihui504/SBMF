# Semantic Bug Mining Framework - Environment Configuration

# ================================================================
# SeekDB Database Configuration
# ================================================================

# SeekDB connection settings
SEEKDB_HOST=localhost
SEEKDB_PORT=2881
SEEKDB_DATABASE=default

# Connection timeout (seconds)
SEEKDB_TIMEOUT=30

# Use real adapter (set to 'false' to force mock adapter)
USE_REAL_ADAPTER=true

# ================================================================
# Test Configuration
# ================================================================

# Test collection name (will be created during tests)
TEST_COLLECTION=test_framework

# Whether to skip tests that require real database
SKIP_DATABASE_TESTS=false

# ================================================================
# Logging Configuration
# ================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable verbose output for tests
VERBOSE_TESTS=false
